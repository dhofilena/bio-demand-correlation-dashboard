# =============================================================================
# Demand Correlation Dashboard — environment configuration
# Copy this file to `.env` and fill in your values. NONE of these are exposed to
# the browser: they are only read by the server proxy / Vite dev middleware.
# (Anything that must reach the client would need a VITE_ prefix — keep secrets
#  WITHOUT that prefix so they never get bundled.)
# =============================================================================

# ---- Triple Whale (website organic traffic, direct, revenue) ----
TW_API_KEY=
TW_SHOP_ID=your-store.myshopify.com
TW_API_BASE=https://api.triplewhale.com

# Set to "live" to call the real adapters. Anything else (or a missing key)
# keeps the app on the deterministic mock adapter so it runs with zero config.
DEMAND_DATA_MODE=mock

# ---- Amazon search (swappable, NOT assumed to be Triple Whale) ----
# 'mock' (default) | 'triplewhale' | 'custom'
AMAZON_ADAPTER=mock
AMAZON_API_BASE=
AMAZON_API_KEY=

# ---- Standalone Express proxy only (not needed for `npm run dev`) ----
PORT=8787
