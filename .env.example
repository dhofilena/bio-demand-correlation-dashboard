# =============================================================================
# Demand Correlation Dashboard — environment configuration
# Copy this file to `.env` and fill in your values. NONE of these are exposed to
# the browser: they are only read by the server proxy / Vite dev middleware.
# (Anything that must reach the client would need a VITE_ prefix — keep secrets
#  WITHOUT that prefix so they never get bundled.)
# =============================================================================

# ---- Triple Whale (website organic traffic, direct, revenue) ----
TW_API_KEY=
TW_SHOP_ID=your-store.myshopify.com
TW_API_BASE=https://api.triplewhale.com
TW_CURRENCY=USD

# Set to "live" to call the real adapters. Anything else (or a missing key)
# keeps the app on the deterministic mock adapter so it runs with zero config.
DEMAND_DATA_MODE=mock

# ---- Google Sheets (private CSV via service account) ----
# Set GOOGLE_SHEETS_ENABLED=true after sharing the workbook with the service account.
# GOOGLE_SHEET_ID = default spreadsheet ID. Tabs can override with their own spreadsheetId.
# Each tab is targeted by gid — open the tab in Sheets and copy from #gid=… in the URL.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TABS=[{"gid":"839768178","label":"Social content","format":"social-scorecard"},{"gid":"1134623476","label":"Podscribe","format":"podscribe"},{"gid":"1638815849","label":"Amazon revenue","format":"amazon-revenue","spreadsheetId":"1_rgLTyvDctpv8wMtBR7TygfY1D8lGUhwyeT8QEG0RYw"}]
GOOGLE_SHEET_GID=0
# Recommended: path to the JSON key downloaded from GCP
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./secrets/google-service-account.json
# Alternative: full JSON on one line (use instead of KEY_FILE)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- Standalone Express proxy only (not needed for `npm run dev` or Netlify) ----
PORT=8787

# ---- Netlify production ----
# Set the same variables in Site settings → Environment variables.
# On Netlify, use GOOGLE_SERVICE_ACCOUNT_JSON (not KEY_FILE) — the secrets/
# folder is not deployed.
